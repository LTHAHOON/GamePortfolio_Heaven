{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "f823f95dd24341b0b8f67c060d651470",
    "m_Title": "Screen Space Outline 방식(Post process Edge Detection)",
    "m_Content": "깊이 차이를 이용하여 아웃라인을 그릴지 말지 정하는 로직입니다.\nScreen 위치를 이용하였기 때문에 프레임이 해상도의 영향을 많이 받을 수도 있다고 생각합니다. 하지만 일반 Outline처럼 덮어 씌우는 과정이 아니기 때문에 유닛이 많을 경우 오히려 좋을 수도 있고 내부까지 Post Process가 적용이 가능해서 퀄리티를 높일 수 있습니다.\n\n",
    "m_TextSize": 1,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -3520.0,
        "y": -689.5999755859375,
        "width": 1144.133544921875,
        "height": 193.00039672851563
    },
    "m_Group": {
        "m_Id": ""
    }
}

